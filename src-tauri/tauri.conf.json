{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TriLog",
  "version": "1.0.3",
  "identifier": "com.TriLog.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TriLog",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "minWidth": 500,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: asset:; img-src 'self' asset: blob: data:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDIR/asset/**",
          "$APPDIR/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
